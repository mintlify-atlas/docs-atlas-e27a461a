  "keyFeatures": [
    "Full PrimeNG v21 component coverage with custom design tokens for every component",
    "Two-level design token architecture: Primitive tokens (brand color palettes) + Semantic tokens (role-based references)",
    "Light and dark mode support via configurable darkModeSelector",
    "Extends PrimeNG's Aura base preset using @primeuix/themes definePreset API",
    "Custom brand color palettes: Navy Primary, Sky Blue Secondary, Cyan Success, Orange Warning, Red Error",
    "Per-component CSS overrides via global css token to remove transition flicker",
    "Published to GitHub Packages as @nettalco/nettalco-theme",
    "PowerShell publish script with semver bumping and git tagging"
  ],
  "publicApiSurface": [
    "MyPreset (default export) — the PrimeNG preset object to pass to providePrimeNG()",
    "definePreset(Aura, { primitive, semantic, css, components }) — @primeuix/themes API used internally",
    "primitive.nettalcoPrimary — Navy blue brand palette (50–950)",
    "primitive.nettalcoSecondary — Sky blue brand palette (50–950)",
    "primitive.nettalcoSuccess — Cyan brand palette (50–950)",
    "primitive.nettalcoWarn — Orange brand palette (50–950)",
    "primitive.nettalcoInfo — Info blue brand palette (50–950)",
    "semantic.colorScheme.light / dark — Light and dark mode semantic token overrides",
    "components.* — Per-component design token objects (button, card, datatable, select, …)"
  ]
}
